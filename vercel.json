{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/audit.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/audit", "destination": "/api/audit.js" },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "drinkware.picolotales.com" }],
      "destination": "/experiment/drinkware"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "drinkware.picolotales.com" }],
      "destination": "/experiment/drinkware/:path*"
    },
    { "source": "/", "destination": "/main" }
  ]
}
